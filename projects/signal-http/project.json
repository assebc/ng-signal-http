{
  "name": "ng-signal-http",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "projects/signal-http/src",
  "prefix": "sh",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": [
        "dist/{projectRoot}"
      ],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "project": "projects/signal-http/ng-package.json",
        "tsConfig": "projects/signal-http/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "projects/signal-http/tsconfig.lib.prod.json"
        },
        "development": {}
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {
        "watch": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
